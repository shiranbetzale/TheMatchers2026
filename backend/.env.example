PORT=4000

# Firebase Admin credentials are required for push notifications and image uploads.
# Prefer the Base64 variant on Render to avoid JSON escaping issues.
FIREBASE_SERVICE_ACCOUNT_JSON_BASE64=
# FIREBASE_SERVICE_ACCOUNT_JSON=

FIREBASE_STORAGE_BUCKET=thematchers-39ff5.firebasestorage.app

# Required for candidate verification by a voice call (kosher phones).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=
